# Copia este archivo a .env.local y reemplaza los valores cuando los tengas.

# Dominio del sitio (sin slash final). Reemplazar cuando tengas tu dominio real.
NEXT_PUBLIC_SITE_URL=https://TU-DOMINIO.com

# Email de soporte que se muestra en el sitio. Reemplazar por el real.
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@TU-DOMINIO.com

# Stripe Payment Links. Reemplazar cada uno cuando crees tus links reales en Stripe.
NEXT_PUBLIC_STRIPE_EXPRESS_LINK=https://buy.stripe.com/PLACEHOLDER_EXPRESS
NEXT_PUBLIC_STRIPE_PRO_LINK=https://buy.stripe.com/PLACEHOLDER_PRO
NEXT_PUBLIC_STRIPE_COMPLETO_LINK=https://buy.stripe.com/PLACEHOLDER_COMPLETO
